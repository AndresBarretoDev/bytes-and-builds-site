

# WordPress API Configuration
NEXT_PUBLIC_WORDPRESS_API_URL=url
WORDPRESS_API_USER=wordpress admin
WORDPRESS_APP_PASSWORD=XXXX XXXX XXXX XXXX XXXX XXXX

# Resend (formulario de contacto)
RESEND_API_KEY=re_xxxxxxxxx

# Cloudflare Turnstile (anti-bot en formulario de contacto)
# Obtén las claves en: https://dash.cloudflare.com/ → Turnstile
NEXT_PUBLIC_TURNSTILE_SITE_KEY=0x4AAAAAAA...   # Clave pública (expuesta al cliente)
TURNSTILE_SECRET_KEY=0x4AAAAAAA...              # Clave secreta (solo servidor)